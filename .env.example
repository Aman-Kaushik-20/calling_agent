# ─── Bolna (required) ────────────────────────────────────────────────────────
BOLNA_API_KEY=your_bolna_api_key
BOLNA_BASE_URL=https://api.bolna.ai

# ─── Slack (optional) ────────────────────────────────────────────────────────
# Set both to enable. SLACK_BOT_TOKEN needs chat:write; bot must be in the channel.
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token
SLACK_BASE_URL=https://slack.com/api
SLACK_ALERT_CHANNEL=your-slack-channel-name

# ─── Discord (optional) ──────────────────────────────────────────────────────
# Channel → Edit Channel → Integrations → Webhooks → New. Paste the URL.
DISCORD_WEBHOOK_URL=

# ─── Mattermost (optional) ───────────────────────────────────────────────────
# Incoming webhook URL — Slack-compatible payload shape.
MATTERMOST_WEBHOOK_URL=

# ─── ClickUp (optional) ──────────────────────────────────────────────────────
# Personal API token (pk_…) + the task ID that should receive comments.
CLICKUP_API_TOKEN=
CLICKUP_TASK_ID=
